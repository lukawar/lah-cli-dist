#!/usr/bin/env sh
set -e
DIR="$(cd "$(dirname "$0")" && pwd)"
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH="$(uname -m)"
case "$ARCH" in
  x86_64) ARCH="amd64" ;;
  arm64|aarch64) ARCH="arm64" ;;
  *) echo "lah-cli: unsupported architecture: $ARCH" >&2; exit 1 ;;
esac
exec "$DIR/lah-cli-${OS}-${ARCH}" "$@"
